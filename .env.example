# Copy to .env.local (gitignored). Restart `npm run dev` after editing.

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""
# Anon (public) key — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server only, NEVER expose to the client. Used by
# /api/signup to insert into the waitlist table without RLS friction.
SUPABASE_SERVICE_ROLE_KEY=""

# --- App ---
# Public origin used in metadata, OG URLs, and emails.
NEXT_PUBLIC_SITE_URL="https://toosoon.example"
